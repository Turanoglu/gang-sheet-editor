{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gang Sheet Editor</title>
  <style>
    html, body {
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
      height: 100% !important;
      overflow: hidden !important;
    }
    #gang-sheet-wrapper {
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      width: 100% !important;
      height: 100% !important;
      z-index: 2147483647 !important;
      border: none !important;
    }
  </style>
</head>
<body>

  <iframe
    id="gang-sheet-wrapper"
    src="https://gang-sheet-editor.vercel.app/?{% if customer %}customerId={{ customer.id }}&customerEmail={{ customer.email | url_encode }}&{% endif %}shop=inkdyno"
    allow="clipboard-read; clipboard-write"
  ></iframe>

  {% if customer %}
  <script>
    var iframe = document.getElementById('gang-sheet-wrapper');
    iframe.addEventListener('load', function() {
      iframe.contentWindow.postMessage({
        type: 'SHOPIFY_CUSTOMER',
        customerId: '{{ customer.id }}',
        customerEmail: '{{ customer.email }}',
        customerName: '{{ customer.first_name }} {{ customer.last_name }}'
      }, 'https://gang-sheet-editor.vercel.app');
    });
  </script>
  {% endif %}

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      Array.from(document.body.children).forEach(function(el) {
        if (el.id !== 'gang-sheet-wrapper') el.style.display = 'none';
      });
    });
  </script>

  <!-- Gang Sheet Checkout: editor'dan gelen postMessage'ı yakala, Shopify cart'a ekle -->
  <!-- NOTE: Uses XMLHttpRequest instead of fetch to bypass third-party fetch interceptors (e.g. interceptor.js) -->
  <script>
    function xhrRequest(method, url, body) {
      return new Promise(function(resolve, reject) {
        var xhr = new XMLHttpRequest();
        xhr.open(method, url, true);
        if (body) xhr.setRequestHeader('Content-Type', 'application/json');
        xhr.onload = function() {
          if (xhr.status >= 200 && xhr.status < 300) {
            resolve({ ok: true, status: xhr.status, responseText: xhr.responseText });
          } else {
            try {
              var data = JSON.parse(xhr.responseText);
              reject(new Error(data.description || data.message || 'HTTP ' + xhr.status));
            } catch(e) {
              reject(new Error('HTTP ' + xhr.status));
            }
          }
        };
        xhr.onerror = function() { reject(new Error('Network error calling ' + url)); };
        xhr.send(body ? JSON.stringify(body) : null);
      });
    }

    window.addEventListener('message', function(event) {
      // Sadece editor'dan gelen mesajları kabul et
      if (event.origin !== 'https://gang-sheet-editor.vercel.app') return;
      if (!event.data || event.data.type !== 'gang-sheet-checkout') return;

      var items = event.data.items;
      if (!items || items.length === 0) return;

      (async function() {
        try {
          // 1. Mevcut cart'ı temizle
          await xhrRequest('POST', '/cart/clear.js', null);

          // 2. Her gang sheet item'ı Shopify cart'a ekle
          for (var i = 0; i < items.length; i++) {
            var item = items[i];
            await xhrRequest('POST', '/cart/add.js', {
              id: item.variantId,
              quantity: item.quantity,
              properties: item.properties
            });
          }

          // 3. Shopify checkout'a yönlendir
          window.location.href = '/checkout';

        } catch (e) {
          console.error('Gang Sheet checkout error:', e);
          alert('Checkout failed: ' + e.message + '\n\nPlease try again or contact support.');
        }
      })();
    });
  </script>

</body>
</html>
