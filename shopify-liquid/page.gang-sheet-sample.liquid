{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gang Sheet Editor</title>
  <style>
    html, body {
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
      height: 100% !important;
      overflow: hidden !important;
    }
    #gang-sheet-wrapper {
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      width: 100% !important;
      height: 100% !important;
      z-index: 2147483647 !important;
      border: none !important;
    }
  </style>
</head>
<body>

  <iframe
    id="gang-sheet-wrapper"
    src="https://gang-sheet-editor.vercel.app/?{% if customer %}customerId={{ customer.id }}&customerEmail={{ customer.email | url_encode }}&{% endif %}shop=inkdyno"
    allow="clipboard-read; clipboard-write"
  ></iframe>

  {% if customer %}
  <script>
    var iframe = document.getElementById('gang-sheet-wrapper');
    iframe.addEventListener('load', function() {
      iframe.contentWindow.postMessage({
        type: 'SHOPIFY_CUSTOMER',
        customerId: '{{ customer.id }}',
        customerEmail: '{{ customer.email }}',
        customerName: '{{ customer.first_name }} {{ customer.last_name }}'
      }, 'https://gang-sheet-editor.vercel.app');
    });
  </script>
  {% endif %}

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      Array.from(document.body.children).forEach(function(el) {
        if (el.id !== 'gang-sheet-wrapper') el.style.display = 'none';
      });
    });
  </script>

  <!-- Gang Sheet Checkout: editor'dan gelen postMessage'ı yakala, Shopify cart'a ekle -->
  <script>
    window.addEventListener('message', async function(event) {
      // Sadece editor'dan gelen mesajları kabul et
      if (event.origin !== 'https://gang-sheet-editor.vercel.app') return;
      if (!event.data || event.data.type !== 'gang-sheet-checkout') return;

      var items = event.data.items;
      if (!items || items.length === 0) return;

      try {
        // 1. Mevcut cart'ı temizle (istemiyorsan bu satırı sil)
        await fetch('/cart/clear.js', { method: 'POST' });

        // 2. Her gang sheet item'ı Shopify cart'a ekle
        for (var i = 0; i < items.length; i++) {
          var item = items[i];
          var response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              id: item.variantId,
              quantity: item.quantity,
              properties: item.properties  // Design Name, Board Size, Images Count, Preview
            })
          });

          if (!response.ok) {
            var err = await response.json().catch(function() { return {}; });
            throw new Error(err.description || 'Failed to add item to cart (variant ID: ' + item.variantId + ')');
          }
        }

        // 3. Shopify checkout'a yönlendir
        window.location.href = '/checkout';

      } catch (e) {
        console.error('Gang Sheet checkout error:', e);
        alert('Checkout failed: ' + e.message + '\n\nPlease try again or contact support.');
      }
    });
  </script>

</body>
</html>
