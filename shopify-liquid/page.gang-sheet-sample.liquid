{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gang Sheet Editor</title>
  <style>
    html, body {
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
      height: 100% !important;
      overflow: hidden !important;
    }
    #gang-sheet-wrapper {
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      width: 100% !important;
      height: 100% !important;
      z-index: 2147483647 !important;
      border: none !important;
    }
  </style>
</head>
<body>

  <iframe
    id="gang-sheet-wrapper"
    src="https://gang-sheet-editor.vercel.app/?{% if customer %}customerId={{ customer.id }}&customerEmail={{ customer.email | url_encode }}&customerName={{ customer.first_name | append: ' ' | append: customer.last_name | strip | url_encode }}&shopDomain={{ shop.permanent_domain | url_encode }}&{% endif %}shop=inkdyno"
    allow="clipboard-read; clipboard-write"
  ></iframe>

  {% if customer %}
  <script>
    var iframe = document.getElementById('gang-sheet-wrapper');
    iframe.addEventListener('load', function() {
      iframe.contentWindow.postMessage({
        type: 'SHOPIFY_CUSTOMER',
        customerId: '{{ customer.id }}',
        customerEmail: '{{ customer.email }}',
        customerName: '{{ customer.first_name }} {{ customer.last_name }}',
        shopDomain: '{{ shop.permanent_domain }}'
      }, 'https://gang-sheet-editor.vercel.app');
    });
  </script>
  {% endif %}

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      Array.from(document.body.children).forEach(function(el) {
        if (el.id !== 'gang-sheet-wrapper' && el.id !== 'gs-login-overlay') el.style.display = 'none';
      });
    });
  </script>

  <!-- Login overlay (hidden by default, shown when editor requests login) -->
  <div id="gs-login-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.7); z-index:2147483646; align-items:center; justify-content:center;">
    <div style="background:#fff; border-radius:16px; padding:40px 32px; max-width:380px; width:90%; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
      <div style="font-size:48px; margin-bottom:16px;">🔒</div>
      <h2 style="margin:0 0 8px; font-size:22px; font-weight:700; color:#1a1a1a;">Sign in to continue</h2>
      <p style="margin:0 0 28px; color:#666; font-size:15px; line-height:1.5;">Please sign in to save your design and add it to your cart.</p>
      <button id="gs-login-btn" style="display:block; width:100%; padding:14px; background:linear-gradient(135deg,#667eea,#764ba2); color:#fff; border:none; border-radius:10px; font-size:16px; font-weight:600; cursor:pointer; margin-bottom:12px;">
        Sign In
      </button>
      <button id="gs-login-cancel" style="display:block; width:100%; padding:12px; background:transparent; color:#666; border:1px solid #ddd; border-radius:10px; font-size:15px; cursor:pointer;">
        Cancel
      </button>
    </div>
  </div>

  <script>
    (function() {
      var overlay = document.getElementById('gs-login-overlay');
      var loginBtn = document.getElementById('gs-login-btn');
      var cancelBtn = document.getElementById('gs-login-cancel');
      var loginPopup = null;

      var iframe = document.getElementById('gang-sheet-wrapper');

      function showLoginOverlay() {
        if (iframe) iframe.style.setProperty('z-index', '1', 'important');
        overlay.style.display = 'flex';
      }

      function hideLoginOverlay() {
        overlay.style.display = 'none';
        if (iframe) iframe.style.setProperty('z-index', '2147483647', 'important');
      }

      loginBtn.addEventListener('click', function() {
        loginPopup = window.open('/account/login', 'shopify-login', 'width=520,height=640,left=' + Math.round((screen.width-520)/2) + ',top=' + Math.round((screen.height-640)/2));
        // Poll until popup closes, then reload page so iframe gets customer params
        var poll = setInterval(function() {
          if (!loginPopup || loginPopup.closed) {
            clearInterval(poll);
            loginPopup = null;
            window.location.reload();
          }
        }, 500);
      });

      cancelBtn.addEventListener('click', hideLoginOverlay);

      // Listen for login request from editor iframe
      window.addEventListener('message', function(event) {
        if (event.origin !== 'https://gang-sheet-editor.vercel.app') return;
        if (event.data && event.data.type === 'gang-sheet-login-required') {
          showLoginOverlay();
        }
      });
    })();
  </script>

  <!-- Gang Sheet Checkout: editor'dan gelen postMessage'ı yakala, Shopify cart'a ekle -->
  <script>
    (function() {
      var isLoggedIn = {{ customer | json }} !== null;

      window.addEventListener('message', function(event) {
        if (event.origin !== 'https://gang-sheet-editor.vercel.app') return;
        if (!event.data || event.data.type !== 'gang-sheet-checkout') return;

        var items = event.data.items;
        if (!items || items.length === 0) return;

        try {
          if (isLoggedIn) {
            // Logged-in: GET chain → /checkout directly
            var finalUrl = '/checkout';
            for (var i = items.length - 1; i >= 0; i--) {
              var item = items[i];
              var params = new URLSearchParams();
              params.set('id', String(item.variantId));
              params.set('quantity', String(item.quantity || 1));
              var props = item.properties || {};
              Object.keys(props).forEach(function(key) {
                params.set('properties[' + key + ']', String(props[key]));
              });
              params.set('return_to', finalUrl);
              finalUrl = '/cart/add?' + params.toString();
            }
            fetch('/cart/clear.js', { method: 'POST' })
              .catch(function() {})
              .then(function() { window.location.href = finalUrl; });

          } else {
            // Guest: add all items via API, then redirect to login → checkout
            var cartItems = items.map(function(item) {
              var props = {};
              Object.keys(item.properties || {}).forEach(function(k) {
                props[k] = String(item.properties[k]);
              });
              return { id: item.variantId, quantity: item.quantity || 1, properties: props };
            });
            fetch('/cart/clear.js', { method: 'POST' })
              .catch(function() {})
              .then(function() {
                return fetch('/cart/add.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ items: cartItems })
                });
              })
              .then(function() {
                window.location.href = '/account/login?return_url=' + encodeURIComponent('/checkout');
              })
              .catch(function() {
                window.location.href = '/account/login?return_url=' + encodeURIComponent('/checkout');
              });
          }

        } catch (e) {
          console.error('[GS] Checkout error:', e);
          alert('Checkout failed: ' + e.message + '\n\nPlease try again or contact support.');
        }
      });
    })();
  </script>

</body>
</html>
