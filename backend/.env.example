# Shopify Custom App Credentials
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_token_here
SHOPIFY_SCOPES=read_products,write_orders,read_customers,write_draft_orders,read_draft_orders

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=your_bucket_name

# Server Config (production URLs after deploy)
HOST=https://your-backend.onrender.com
FRONTEND_URL=https://your-frontend.vercel.app
PORT=3000
